---
import '../styles/global.css';
import '../styles/terminal.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>contact.txt - prajan-karthik</title>
  </head>
  <body>
    <div class="container">
      <div class="terminal-window">
        <div class="panel-header">
          <a href="/">← prajan-karthik@prajan-83dx</a> / contact.txt
        </div>

        <div class="terminal-prompt">$ cat contact.txt</div>
        <div class="terminal-output">
          <div class="panel">
            <div class="panel-header">Get in Touch</div>
            <div class="panel-content">
              <p>I'm always open to discussing new projects, opportunities, or just having a chat about technology.</p>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">Contact Information</div>
            <div class="panel-content">
              <div class="contact-item">
                <span class="contact-icon">📧</span>
                <span>Email: <a href="mailto:prajan.karthik@example.com">prajan.karthik@example.com</a></span>
              </div>
              <div class="contact-item">
                <span class="contact-icon">🔗</span>
                <span>GitHub: <a href="https://github.com/prajan-karthik" target="_blank">github.com/prajan-karthik →</a></span>
              </div>
              <div class="contact-item">
                <span class="contact-icon">💼</span>
                <span>LinkedIn: <a href="https://linkedin.com/in/prajan-karthik" target="_blank">linkedin.com/in/prajan-karthik →</a></span>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">Send a Message</div>
            <div class="panel-content">
              <form
                id="contact-form"
                class="contact-form"
                action="https://formspree.io/f/mnjkwdwr"
                method="POST"
                novalidate
              >
                <div id="form-status" class="form-status" role="status" aria-live="polite"></div>
                <div class="form-group">
                  <label for="name">Name:</label>
                  <input type="text" id="name" name="name" required />
                </div>
                <div class="form-group">
                  <label for="email">Email:</label>
                  <input type="email" id="email" name="email" required />
                </div>
                <div class="form-group">
                  <label for="message">Message:</label>
                  <textarea id="message" name="message" rows="5" required></textarea>
                </div>
                <button type="submit">Send Message</button>
              </form>
            </div>
          </div>
        </div>

        <div class="terminal-prompt">$ cd /</div>
        <div class="terminal-output">
          <a href="/">Return to home →</a>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  .contact-icon {
    font-size: 1.2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .form-group input,
  .form-group textarea {
    background-color: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem;
    border-radius: 0;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  button {
    background-color: var(--bg-secondary);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    border-radius: 0;
    transition: all 0.2s ease;
  }

  button:hover {
    background-color: var(--accent);
    color: var(--bg);
  }

  .form-status {
    min-height: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }

  .form-status--pending {
    color: var(--text-muted);
  }

  .form-status--success {
    color: #0a8a50;
  }

  .form-status--error {
    color: #c53030;
  }
</style>

<script type="module">
  import { createBrowserRateLimiter } from '../lib/rateLimit.mjs';

  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const rateLimiter = createBrowserRateLimiter({
    windowMs: 15 * 60_000,
    maxRequests: 3,
    keyPrefix: 'contact-form',
  });

  if (form && status) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const senderEmail = String(formData.get('email') || '').trim().toLowerCase();
      const rateLimitKey = senderEmail || 'anonymous';

      const allowed = await rateLimiter(rateLimitKey);
      if (!allowed) {
        status.textContent = 'You have reached the 3-message limit for this email address. Please wait a moment before sending another message.';
        status.className = 'form-status form-status--error';
        return;
      }

      status.textContent = 'Sending your message...';
      status.className = 'form-status form-status--pending';
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json',
          },
        });

        const data = await response.json().catch(() => null);

        if (response.ok) {
          form.reset();
          status.textContent = 'Thanks! Your message was sent successfully.';
          status.className = 'form-status form-status--success';
        } else {
          const errorMessage = data?.error || 'Something went wrong. Please try again later.';
          status.textContent = errorMessage;
          status.className = 'form-status form-status--error';
        }
      } catch (error) {
        status.textContent = 'Network error. Please check your connection and try again.';
        status.className = 'form-status form-status--error';
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
