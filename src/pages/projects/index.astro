---
import '../../styles/global.css';
import '../../styles/terminal.css';
import { getRepos } from '../../lib/github';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = await getRepos();
const buildTime = new Date().toISOString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Projects - prajan-karthik</title>
  </head>
  <body>
    <div class="container">
      <div class="terminal-window">
        <div class="panel-header">
          <a href="/">← prajan-karthik@prajan-83dx</a> / projects
        </div>

        <div class="terminal-prompt">$ gh repo list</div>
        <div class="terminal-output">
          <div class="projects-header">
            <h1>Projects</h1>
            <p class="project-count">{projects.length} repositories</p>
            <p class="last-updated">
              Last updated: {new Date(buildTime).toLocaleString()}
            </p>
          </div>
        </div>

        <div class="projects-grid">
          {projects.length > 0 ? (
            projects.map((project: any) => (
              <ProjectCard project={project} />
            ))
          ) : (
            <div class="empty-state">
              <p>No projects found. Check back soon!</p>
              <p class="empty-hint">Make sure GITHUB_TOKEN and GITHUB_USERNAME are set in .env</p>
            </div>
          )}
        </div>

        <div class="terminal-prompt">$ cd /</div>
        <div class="terminal-output">
          <a href="/">Return to home →</a>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .projects-header {
    margin-bottom: 2rem;
  }

  .projects-header h1 {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .project-count {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    border: 1px solid var(--border);
    background-color: var(--bg-secondary);
  }

  .empty-state p {
    font-family: var(--font-body);
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .empty-hint {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
